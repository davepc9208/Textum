# Copia este archivo a .env y rellena con tus propios valores de Supabase
# (Dashboard de Supabase → Project Settings → API)

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anonima-publica

# Para la función de Netlify que envía emails del formulario de contacto
RESEND_API_KEY=tu-api-key-de-resend

# ── Desarrollo local ──────────────────────────────────────────────────────────
# Para probar el formulario de contacto (/api/contact) y el sitemap dinámico:
#   npm run dev:netlify
# Netlify Dev levanta Vite en :5173 y el proxy en :8888 con las funciones serverless.
# También configura RESEND_API_KEY y las variables VITE_* en el dashboard de Netlify.
